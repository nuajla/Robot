<mujoco model="d435i">
  <compiler meshdir="assets/" fitaabb="true"/>

  <visual>
    <global azimuth="90" elevation="-90"/>
  </visual>

  <default>
    <default class="cam">
      <material specular="0" shininess="0.25"/>
      <default class="visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0" mass="0"/>
      </default>
      <default class="collision">
        <geom group="3" type="mesh" mass="0"/>
      </default>
    </default>
  </default>

  <asset>
    <material class="cam" name="Black_Acrylic" rgba="0.070360 0.070360 0.070360 1"/>
    <material class="cam" name="Cameras_Gray" rgba="0.296138 0.296138 0.296138 1"/>
    <material class="cam" name="IR_Emitter_Lens" rgba="0.287440 0.665387 0.327778 1"/>
    <material class="cam" name="IR_Lens" rgba="0.035601 0.035601 0.035601 1"/>
    <material class="cam" name="IR_Rim" rgba="0.799102 0.806952 0.799103 1"/>
    <material class="cam" name="Metal_Casing" rgba="1 1 1 1"/>
    <material class="cam" name="RGB_Pupil" rgba="0.087140 0.002866 0.009346 1"/>

    <mesh file="realsense_d435i/d435i_0.obj"/>
    <mesh file="realsense_d435i/d435i_1.obj"/>
    <mesh file="realsense_d435i/d435i_2.obj"/>
    <mesh file="realsense_d435i/d435i_3.obj"/>
    <mesh file="realsense_d435i/d435i_4.obj"/>
    <mesh file="realsense_d435i/d435i_5.obj"/>
    <mesh file="realsense_d435i/d435i_6.obj"/>
    <mesh file="realsense_d435i/d435i_7.obj"/>
    <mesh file="realsense_d435i/d435i_8.obj"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="1 0 0" directional="true"/>
    <body name="cam" pos="0.013 0 0.015" euler="0 90 90" childclass="cam">
      <site group="5" type="cylinder" pos="0.0625 0 0" quat="0.70711 0 0.70711 0" size="0.005 0.0625" rgba="1 0 0 1"/>
      <site group="5" type="cylinder" pos="0 0.0625 0" quat="0.70711 0.70711 0 0" size="0.005 0.0625" rgba="0 1 0 1"/>
      <site group="5" type="cylinder" pos="0 0 0.0625" quat="1 0 0 0" size="0.005 0.0625" rgba="0 0 1 1"/>

      <geom name="d435i_0" mesh="d435i_0" material="IR_Lens" class="visual"/>
      <geom name="d435i_1" mesh="d435i_1" material="IR_Emitter_Lens" class="visual"/>
      <geom name="d435i_2" mesh="d435i_2" material="IR_Rim" class="visual"/>
      <geom name="d435i_3" mesh="d435i_3" material="IR_Lens" class="visual"/>
      <geom name="d435i_4" mesh="d435i_4" material="Cameras_Gray" class="visual"/>
      <geom name="d435i_5" mesh="d435i_5" material="Black_Acrylic" class="visual"/>
      <geom name="d435i_6" mesh="d435i_6" material="Black_Acrylic" class="visual"/>
      <geom name="d435i_7" mesh="d435i_7" material="RGB_Pupil" class="visual"/>
      <geom name="d435i_8" mesh="d435i_8" mass="0.072" material="Metal_Casing" class="visual"/>
      <geom class="collision" type="capsule" mesh="d435i_8"/>
      <camera name="RGB" fovy="42.5" pos="0.032 0 -0.002" xyaxes="-1 0 0 0 1 0"/>
      <camera name="depth" fovy="58" pos="0 0 0" xyaxes="-1 0 0 0 1 0"/>
      <site name="frame" group="5" type="sphere" pos="0 0 0" quat="0 0 0 1" size="0.001" rgba="1 0 1 1"/>
    </body>
  </worldbody>
</mujoco>

<mujoco model="ur10e">
  <compiler angle="radian" meshdir="assets/" autolimits="true"/>

  <option integrator="implicitfast" timestep="0.001"/>

  <default>
    <default class="robot">
      <material specular="0.5" shininess="0.25"/>
      <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1"/>
      <position ctrlrange="-6.2831 6.2831"/>
      <general biastype="affine" ctrlrange="-6.2831 6.2831" gainprm="5000" biasprm="0 -5000 -500"/>
      <default class="size4">
        <joint damping="10"/>
        <general forcerange="-330 330"/>
      </default>
      <default class="size3">
        <joint damping="5"/>
        <general forcerange="-150 150"/>
        <default class="size3_limited">
          <joint range="-3.1415 3.1415"/>
          <general ctrlrange="-3.1415 3.1415"/>
        </default>
      </default>
      <default class="size2">
        <joint damping="2"/>
        <general forcerange="-56 56"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="cylinder" group="3"  rgba="0.2 .2 0 1"/>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
    </default>
  </default>

  <asset>
    <material class="robot" name="black" rgba="0.033 0.033 0.033 1"/>
    <material class="robot" name="jointgray" rgba="0.278 0.278 0.278 1"/>
    <material class="robot" name="linkgray" rgba="0.82 0.82 0.82 1"/>
    <material class="robot" name="urblue" rgba="0.49 0.678 0.8 1"/>

    <mesh file="ur10e/base_0.obj"/>
    <mesh file="ur10e/base_1.obj"/>
    <mesh file="ur10e/shoulder_0.obj"/>
    <mesh file="ur10e/shoulder_1.obj"/>
    <mesh file="ur10e/shoulder_2.obj"/>
    <mesh file="ur10e/upperarm_0.obj"/>
    <mesh file="ur10e/upperarm_1.obj"/>
    <mesh file="ur10e/upperarm_2.obj"/>
    <mesh file="ur10e/upperarm_3.obj"/>
    <mesh file="ur10e/forearm_0.obj"/>
    <mesh file="ur10e/forearm_1.obj"/>
    <mesh file="ur10e/forearm_2.obj"/>
    <mesh file="ur10e/forearm_3.obj"/>
    <mesh file="ur10e/wrist1_0.obj"/>
    <mesh file="ur10e/wrist1_1.obj"/>
    <mesh file="ur10e/wrist1_2.obj"/>
    <mesh file="ur10e/wrist2_0.obj"/>
    <mesh file="ur10e/wrist2_1.obj"/>
    <mesh file="ur10e/wrist2_2.obj"/>
    <mesh file="ur10e/wrist3.obj"/>
  </asset>

  <worldbody>
    <body name="base" pos="0 0 0" childclass="robot">
      <site name="x" group="1" pos="0.25 0 0" quat="0.707107 0 0.707107 0" size="0.01 0.25" type="cylinder" rgba="1 0 0 1"/>
      <site name="y" group="1" pos="0 0.25 0" quat="0.707107 0.707107 0 0" size="0.01 0.25" type="cylinder" rgba="0 1 0 1"/>
      <site name="z" group="1" pos="0 0 0.25" size="0.01 0.25" type="cylinder" rgba="0 0 1 1"/>
      <body name="base_link" pos="0 0 0" quat="0 0 0 1">
        <inertial pos="0 0 0" quat="0.5 0.5 -0.5 0.5" mass="3.761"  diaginertia="0.01125 0.00610633 0.00610633" />
        <geom mesh="base_0" material="black" class="visual"/>
        <geom mesh="base_1" material="jointgray" class="visual"/>
        <geom class="collision" size="0.078 0.125" pos="0 0 0.15"/>     

        <body name="shoulder_link" pos="0 0 0.1807">
          <inertial pos="0.021 0.0 0.027" mass="7.369" diaginertia="0.0314743 0.0314743 0.0218756" />
          <joint name="shoulder_pan_joint" class="size4" axis="0 0 1"/>
          <geom mesh="shoulder_0" material="urblue" class="visual"/>
          <geom mesh="shoulder_1" material="black" class="visual"/>
          <geom mesh="shoulder_2" material="jointgray" class="visual"/>
        
          <body name="upper_arm_link" pos="0 0.17615 0" quat="0.707107 0 0.707107 0">
            <inertial pos="0.0 -0.0227 0.2327" mass="13.051" diaginertia="0.423074 0.423074 0.0363656" />
            <joint name="shoulder_lift_joint" class="size4"/>
            <geom mesh="upperarm_0" material="black" class="visual"/>
            <geom mesh="upperarm_1" material="jointgray" class="visual"/>
            <geom mesh="upperarm_2" material="urblue" class="visual"/>
            <geom mesh="upperarm_3" material="linkgray" class="visual"/>
            <geom class="collision" size="0.078 0.125" pos="0 -0.02 0" quat="0.707107 0.707107 0 0"/>
            <geom class="collision" size="0.08 0.055" pos="0 0 0.055"/>
            <geom class="collision" size="0.06 0.24" pos="0 0 0.33" />
        
            <body name="forearm_link" pos="0 -0.137 0.6127">
              <inertial pos="0 0.0289 0.3316" mass="3.989" diaginertia="0.11059 0.11059 0.0108844" />
              <joint name="elbow_joint" class="size3_limited"/>
              <geom mesh="forearm_0" material="urblue" class="visual"/>
              <geom mesh="forearm_1" material="black" class="visual"/>
              <geom mesh="forearm_2" material="jointgray" class="visual"/>
              <geom mesh="forearm_3" material="linkgray" class="visual"/>
              <geom class="collision" size="0.06 0.11" pos="0 0.1 0" quat="0.707107 0.707107 0 0"/>
              <geom class="collision" size="0.046 0.26" pos="0 0 0.30" />
              <geom class="collision" size="0.06 0.06" pos="0 0 0.025" />
        
              <body name="wrist_1_link" pos="0 0 0.57155" quat="0.707107 0 0.707107 0">
                <inertial  pos="0 0.142 0.018" quat="0.5 0.5 -0.5 0.5" mass="2.1" diaginertia="0.0055125 0.00510825 0.00510825" />
                <joint name="wrist_1_joint" class="size2"/>
                <geom mesh="wrist1_0" material="black" class="visual"/>
                <geom mesh="wrist1_1" material="urblue" class="visual"/>
                <geom mesh="wrist1_2" material="jointgray" class="visual"/>
                <geom class="collision" size="0.05 0.08" pos="0 0.02 0" quat="0.707107 0.707107 0 0" />
        
                <body name="wrist_2_link" pos="0 0.135 0">
                  <inertial pos="0 0.0180 0.1129" quat="0.5 0.5 -0.5 0.5" mass="1.98" diaginertia="0.0055125 0.00510825 0.00510825" />
                  <joint name="wrist_2_joint" axis="0 0 1" class="size2"/>
                  <geom mesh="wrist2_0" material="black" class="visual"/>
                  <geom mesh="wrist2_1" material="urblue" class="visual"/>
                  <geom mesh="wrist2_2" material="jointgray" class="visual"/>
                  <geom class="collision" size="0.048 0.085" pos="0 0 0.02"/>
                  <geom class="collision" size="0.048 0.07" pos="0 0.008 0.12" quat="0.707107 0.707107 0 0"/>
        
                  <body name="wrist_3_link" pos="0 0 0.11985">
                    <inertial pos="0 0.0905 0" quat="6.34592e-10 0.707107 -0.707107 6.34592e-10" mass="0.615" diaginertia="0.000204525 0.000144346 0.000144346" />
                    <joint name="wrist_3_joint" class="size2"/>
                    <geom material="linkgray" mesh="wrist3" class="visual"/>
                    <geom class="collision" size="0.048 0.02" pos="0 0.097 0" quat="0.707107 0.707107 0 0"/>
        
                    <body name="flange" pos="0 0.11655 0" quat="0.707107 -0.707107 0 0">
                      <site group="3" type="cylinder" pos="0.125 0 0" quat="0.70711 0 0.70711 0" size="0.005 0.125" rgba="1 0 0 1"/>
                      <site group="3" type="cylinder" pos="0 0.125 0" quat="0.70711 0.70711 0 0" size="0.005 0.125" rgba="0 1 0 1"/>
                      <site group="3" type="cylinder" pos="0 0 0.125" quat="1 0 0 0" size="0.005 0.125" rgba="0 0 1 1"/>
                      <site name="flange" pos="0 0 0"/>
                      <site name="TCP" pos="0 0 0"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="base_link" body2="upper_arm_link"/>
  </contact>
  
  <actuator>
    <general class="size4" name="shoulder_pan_actuator" joint="shoulder_pan_joint"/>
    <general class="size4" name="shoulder_lift_actuator" joint="shoulder_lift_joint"/>
    <general class="size3_limited" name="elbow_actuator" joint="elbow_joint"/>
    <general class="size2" name="wrist_1_actuator" joint="wrist_1_joint"/>
    <general class="size2" name="wrist_2_actuator" joint="wrist_2_joint"/>
    <general class="size2" name="wrist_3_actuator" joint="wrist_3_joint"/>
  </actuator>

  <sensor>
    <framepos name="pos" objtype="site" objname="TCP" />
    <framequat name="ori" objtype="site" objname="TCP" />
    <framelinvel name="v" objtype="site" objname="TCP" />
    <frameangvel name="w" objtype="site" objname="TCP" />
    <force name="force" site="TCP" noise="0.5" />
    <torque name="torque" site="TCP" noise="0.5" />
  </sensor>
    
  <keyframe>
    <key name="home" qpos="1.5708 -1.5708 -1.5708 0 1.5708 0" ctrl="1.5708 -1.5708 -1.5708 0 1.5708 0"/>
  </keyframe>
</mujoco>


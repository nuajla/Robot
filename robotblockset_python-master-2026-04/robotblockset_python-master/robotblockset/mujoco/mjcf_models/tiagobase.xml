      <joint limited="false" armature="5" damping="5"/>
      <geom contype="0" condim="4" margin="0.0001" material="BodyWhite"/>
      <site size="0.01 0.005 0.005" group="3"/>
      <general ctrllimited="false" ctrlrange="-3000 3000" gainprm="320" biasprm="0 -320 -20"/>
    </default>
  </default>


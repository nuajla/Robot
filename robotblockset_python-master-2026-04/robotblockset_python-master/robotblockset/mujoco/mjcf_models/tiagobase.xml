<mujoco model="TiagoBase">
  <compiler angle="radian" meshdir="assets/" texturedir="assets/"/>

  <option integrator="implicit"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" specular="0 0 0"/>
    <map fogstart="6"/>
    <scale framelength="2" framewidth="0.02"/>
  </visual>

  <default>
    <light castshadow="false"/>
    <general biastype="affine" biasprm="0 -1"/>

  <!-- Base -->
  <!-- Courier rgbd sensors -->
  <xacro:if value="$(arg add_on_module)">
    <xacro:if value="$(arg camera_model)">
      <!-- RGBD base -->
      <joint name="base_rgbd_camera_joint" type="fixed">
        <origin xyz="0.22697 0.0 0.535" rpy="-0.002996887405306943 1.0471975511965976 0.0"/>
        <axis xyz="0 0 1"/>
        <!-- <limit lower="0" upper="0.001" effort="100" velocity="0.01"/> -->
        <parent link="base_link"/>

      <link name="base_rgbd_camera_depth_optical_frame"/>
      <gazebo reference="base_rgbd_camera_link">
        <!-- IR + depth -->
        <sensor type="depth" name="base_rgbd_camera_frame_sensor">
          <always_on>true</always_on>
          <update_rate>6.0</update_rate>
          <camera>

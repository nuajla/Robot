          <origin xyz="-0.01 0.0025 0" rpy="0 0 0"/>
          <geometry>
            <box size="0.04 0.185 0.03"/>
          </geometry>
        </collision>
      </link>
      <joint name="base_rgbd_camera_optical_joint" type="fixed">
        <origin xyz="0 0 0" rpy="-1.5707963267948966 0 -1.5707963267948966"/>
